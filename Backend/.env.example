# Local LifeOrganize backend configuration template.
# Copy to Backend/.env and fill secret values. Do not commit Backend/.env.
ENVIRONMENT=development

POSTGRES_DB=lifeorganize
POSTGRES_USER=lifeorganize
POSTGRES_PASSWORD=lifeorganize
POSTGRES_PORT=5433
DATABASE_URL=postgresql+asyncpg://lifeorganize:lifeorganize@localhost:5433/lifeorganize
RUN_MIGRATIONS=true

OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.5

DEVICE_TOKEN_SIGNING_SECRET=
LIFE_ORGANIZE_ADMIN_API_KEY=
DEVICE_RATE_LIMIT_REQUESTS=60
DEVICE_RATE_LIMIT_WINDOW_SECONDS=3600
